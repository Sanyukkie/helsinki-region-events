# Copy to .env and fill in. Everything works without it — Ticketmaster is just skipped.

# Free key from https://developer.ticketmaster.com (instant signup, 5000 req/day)
TICKETMASTER_API_KEY=

# How far ahead to ingest events (days)
INGEST_DAYS=45

# Kide.app student/club events (unofficial API — see README). On by default; set 0 to disable.
KIDE_ENABLED=1

PORT=4173
